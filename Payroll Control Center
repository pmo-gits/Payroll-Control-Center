/*******************************************************
 * Payroll Control Center
 * - Custom menu: Generate Payroll Workings
 * - Reads Month / Year from the first unlocked row in PAYROLL_CONTROL
 * - Creates copy of template in Monthly Payroll Workings folder
 * - Updates copied file META_DATA
 * - Writes row in PAYROLL_CONTROL
 * - Rebuilds script-managed protections on completed rows
 *
 * REQUIRED TABS:
 * 1) PAYROLL_CONTROL
 * 2) CONFIG
 * 3) META_DATA (inside template file)
 *
 * CONFIG KEYS REQUIRED:
 * - TEMPLATE_PAYROLL_GENERATOR_FILE_ID
 * - MONTHLY_PAYROLL_WORKINGS_FOLDER_ID
 * - LOCKED_PAYROLL_FILES_FOLDER_ID
 * - BANK_TRANSFER_FILES_FOLDER_ID
 * - CONTROL_FILE_NAME
 *******************************************************/

const PCC = Object.freeze({
  SHEETS: Object.freeze({
    PAYROLL_CONTROL: 'PAYROLL_CONTROL',
    CONFIG: 'CONFIG',
    META_DATA: 'META_DATA',
  }),

  INPUTS: Object.freeze({
    HEADER_ROW: 1,
    FIRST_DATA_ROW: 2,
  }),

  HEADERS: Object.freeze({
    PAYROLL_MONTH_KEY: 'PAYROLL_MONTH_KEY',
    MONTH: 'MONTH',
    YEAR: 'YEAR',
    PAYROLL_WORKINGS_FILE_NAME: 'PAYROLL_WORKINGS_FILE_NAME',
    PAYROLL_WORKINGS_FILE_ID: 'PAYROLL_WORKINGS_FILE_ID',
    LOCK_STATUS: 'LOCK_STATUS',
    CREATED_ON: 'CREATED_ON',
    CREATED_BY: 'CREATED_BY',
  }),

  CONFIG_KEYS: Object.freeze({
    TEMPLATE_FILE_ID: 'TEMPLATE_PAYROLL_GENERATOR_FILE_ID',
    WORKINGS_FOLDER_ID: 'MONTHLY_PAYROLL_WORKINGS_FOLDER_ID',
    LOCKED_PAYROLL_FOLDER_ID: 'LOCKED_PAYROLL_FILES_FOLDER_ID',
    BANK_TRANSFER_FOLDER_ID: 'BANK_TRANSFER_FILES_FOLDER_ID',
    CONTROL_FILE_NAME: 'CONTROL_FILE_NAME',
  }),

  META_KEYS: Object.freeze({
    PAYROLL_MONTH_LABEL: 'PAYROLL_MONTH_LABEL',
    LOCK_STATUS: 'LOCK_STATUS',
  }),

  VALUES: Object.freeze({
    LOCK_STATUS_OPEN: 'OPEN',
    LOCK_STATUS_LOCKED: 'LOCKED',
  }),

  PROTECTION: Object.freeze({
    DESCRIPTION_PREFIX: 'PCC_MANAGED_PROTECTION',
  }),
});

/**
 * SINGLE MENU FOR THIS FILE
 */
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('Payroll Control')
    .addItem('Generate Payroll Workings', 'generatePayrollWorkings')
    .addToUi();
}

/**
 * MAIN
 */
function generatePayrollWorkings() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const lock = LockService.getScriptLock();

  const protectionContext = {
    sheet: null,
    headerMap: null,
    rowsToProtect: [],
    protectionsRemoved: false,
  };

  try {
    lock.waitLock(30000);
  } catch (e) {
    ui.alert(
      'Generate Payroll Workings',
      'Another payroll workings generation is already running. Please wait a moment and try again.',
      ui.ButtonSet.OK
    );
    return;
  }

  try {
    const config = getConfigMap_();

    validateControlFileName_(ss, config);

    const sh = ss.getSheetByName(PCC.SHEETS.PAYROLL_CONTROL);
    if (!sh) throw new Error(`Sheet not found: ${PCC.SHEETS.PAYROLL_CONTROL}`);

    const headerMap = getHeaderMap_(sh, PCC.INPUTS.HEADER_ROW);
    protectionContext.sheet = sh;
    protectionContext.headerMap = headerMap;

    validateRequiredHeaders_(headerMap, [
      PCC.HEADERS.PAYROLL_MONTH_KEY,
      PCC.HEADERS.MONTH,
      PCC.HEADERS.YEAR,
      PCC.HEADERS.PAYROLL_WORKINGS_FILE_NAME,
      PCC.HEADERS.PAYROLL_WORKINGS_FILE_ID,
      PCC.HEADERS.LOCK_STATUS,
      PCC.HEADERS.CREATED_ON,
      PCC.HEADERS.CREATED_BY,
    ]);

    // Step 1: find first row where LOCK_STATUS is not LOCKED
    const nextRow = findFirstUnlockedRow_(sh, headerMap);

    // Step 2: stop if any lower row already contains data before current unlocked row is completed
    const sequenceCheck = validateSequentialEntryDiscipline_(sh, headerMap, nextRow);
    if (sequenceCheck.block) {
      ui.alert('Generate Payroll Workings', sequenceCheck.message, ui.ButtonSet.OK);
      return;
    }

    // Step 3: if workings already created for this row but lock not completed, stop
    const existingFileName = String(sh.getRange(nextRow, headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_NAME]).getDisplayValue() || '').trim();
    const existingFileId = String(sh.getRange(nextRow, headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_ID]).getDisplayValue() || '').trim();
    const existingLockStatus = String(sh.getRange(nextRow, headerMap[PCC.HEADERS.LOCK_STATUS]).getDisplayValue() || '').trim().toUpperCase();

    if ((existingFileName || existingFileId) && existingLockStatus !== PCC.VALUES.LOCK_STATUS_LOCKED) {
      ui.alert(
        'Generate Payroll Workings',
        `Row ${nextRow} already has a payroll workings reference but LOCK_STATUS is not LOCKED.\n\nPlease complete the lock process for this row first before generating the next payroll workings file.`,
        ui.ButtonSet.OK
      );
      return;
    }

    // Step 4: read Month / Year from first unlocked row
    const monthYearVals = sh.getRange(nextRow, headerMap[PCC.HEADERS.MONTH], 1, 2).getDisplayValues()[0];
    const month = String(monthYearVals[0] || '').trim();
    const year = String(monthYearVals[1] || '').trim();

    if (!month) {
      ui.alert(
        'Generate Payroll Workings',
        `Month is blank in row ${nextRow}. Please select Month in that row first.`,
        ui.ButtonSet.OK
      );
      return;
    }

    if (!year) {
      ui.alert(
        'Generate Payroll Workings',
        `Year is blank in row ${nextRow}. Please select Year in that row first.`,
        ui.ButtonSet.OK
      );
      return;
    }

    if (!/^\d{4}$/.test(year)) {
      ui.alert(
        'Generate Payroll Workings',
        `Year in row ${nextRow} must be a 4-digit value.`,
        ui.ButtonSet.OK
      );
      return;
    }

    const payrollMonthKey = `${month}_${year}`;
    const fileName = `Payroll-Workings_${month}_${year}`;

    // Step 5: duplicate checks inside control sheet
    const duplicateCheck = checkDuplicateInControl_(sh, headerMap, payrollMonthKey, fileName, nextRow);
    if (duplicateCheck.block) {
      ui.alert('Generate Payroll Workings', duplicateCheck.message, ui.ButtonSet.OK);
      return;
    }

    // Step 6: duplicate check in target folder
    const workingsFolderId = String(config[PCC.CONFIG_KEYS.WORKINGS_FOLDER_ID] || '').trim();
    if (!workingsFolderId) throw new Error(`Missing CONFIG value: ${PCC.CONFIG_KEYS.WORKINGS_FOLDER_ID}`);

    if (folderHasExactFileName_(workingsFolderId, fileName)) {
      ui.alert(
        'Generate Payroll Workings',
        `A workings file named "${fileName}" already exists in the Monthly Payroll Workings folder. Duplicate creation is blocked.`,
        ui.ButtonSet.OK
      );
      return;
    }

    // Step 7: create file copy
    const templateFileId = String(config[PCC.CONFIG_KEYS.TEMPLATE_FILE_ID] || '').trim();
    if (!templateFileId) throw new Error(`Missing CONFIG value: ${PCC.CONFIG_KEYS.TEMPLATE_FILE_ID}`);

    const templateFile = DriveApp.getFileById(templateFileId);
    const workingsFolder = DriveApp.getFolderById(workingsFolderId);

    const copiedFile = templateFile.makeCopy(fileName, workingsFolder);
    const copiedFileId = copiedFile.getId();

    // Step 8: update copied file META_DATA
    const copiedSs = SpreadsheetApp.openById(copiedFileId);
    updateMetaDataKeys_(copiedSs, {
      [PCC.META_KEYS.PAYROLL_MONTH_LABEL]: payrollMonthKey,
      [PCC.META_KEYS.LOCK_STATUS]: PCC.VALUES.LOCK_STATUS_OPEN,
    });

    // Step 9: write values in same active row
    const createdOn = new Date();
    const createdBy = Session.getActiveUser().getEmail() || '';

    sh.getRange(nextRow, headerMap[PCC.HEADERS.PAYROLL_MONTH_KEY]).setValue(payrollMonthKey);
    sh.getRange(nextRow, headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_NAME]).setValue(fileName);
    sh.getRange(nextRow, headerMap[PCC.HEADERS.CREATED_ON]).setValue(createdOn);
    sh.getRange(nextRow, headerMap[PCC.HEADERS.CREATED_BY]).setValue(createdBy);

    SpreadsheetApp.flush();

    // Write clickable file link LAST
    sh.getRange(nextRow, headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_ID])
      .setFormula(`=HYPERLINK("https://docs.google.com/spreadsheets/d/${copiedFileId}/edit","${copiedFileId}")`);

    SpreadsheetApp.flush();

    // Step 10: protect all rows where workings file name is filled
    const rowsToProtect = getProtectedRowsByFileName_(sh, headerMap);
    protectionContext.rowsToProtect = rowsToProtect;

    removeScriptManagedProtections_(sh);
    protectionContext.protectionsRemoved = true;

    restoreManagedProtections_(sh, headerMap, rowsToProtect);
    protectionContext.protectionsRemoved = false;

    ui.alert(
      'Generate Payroll Workings',
      `Payroll workings file created successfully.\n\nFile Name: ${fileName}\nRow: ${nextRow}`,
      ui.ButtonSet.OK
    );

  } catch (err) {
    try {
      if (
        protectionContext.protectionsRemoved &&
        protectionContext.sheet &&
        protectionContext.headerMap
      ) {
        restoreManagedProtections_(
          protectionContext.sheet,
          protectionContext.headerMap,
          protectionContext.rowsToProtect || []
        );
      }
    } catch (restoreErr) {
      // keep original error as main failure
    }

    SpreadsheetApp.getUi().alert(
      'Generate Payroll Workings',
      `Error: ${err && err.message ? err.message : err}`,
      SpreadsheetApp.getUi().ButtonSet.OK
    );
    return;
  } finally {
    try {
      lock.releaseLock();
    } catch (e) {
      // no-op
    }
  }
}

/**
 * Reads CONFIG sheet as key/value map.
 * Expected:
 * Column A = KEY
 * Column B = VALUE
 */
function getConfigMap_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(PCC.SHEETS.CONFIG);
  if (!sh) throw new Error(`Sheet not found: ${PCC.SHEETS.CONFIG}`);

  const lastRow = sh.getLastRow();
  if (lastRow < 1) throw new Error('CONFIG sheet is empty.');

  const values = sh.getRange(1, 1, lastRow, 2).getDisplayValues();
  const map = {};

  for (let i = 0; i < values.length; i++) {
    const key = String(values[i][0] || '').trim();
    const value = String(values[i][1] || '').trim();
    if (key) map[key] = value;
  }

  return map;
}

/**
 * Validates active file name against CONFIG.
 */
function validateControlFileName_(ss, config) {
  const expectedName = String(config[PCC.CONFIG_KEYS.CONTROL_FILE_NAME] || '').trim();
  if (!expectedName) throw new Error(`Missing CONFIG value: ${PCC.CONFIG_KEYS.CONTROL_FILE_NAME}`);

  const actualName = String(ss.getName() || '').trim();
  if (actualName !== expectedName) {
    throw new Error(`This script must run from "${expectedName}" only. Current file: "${actualName}"`);
  }
}

/**
 * Header map: { HEADER_NAME: columnNumber }
 */
function getHeaderMap_(sheet, headerRow) {
  const lastCol = sheet.getLastColumn();
  const headers = sheet.getRange(headerRow, 1, 1, lastCol).getDisplayValues()[0];
  const map = {};

  for (let c = 0; c < headers.length; c++) {
    const h = String(headers[c] || '').trim();
    if (h) map[h] = c + 1;
  }

  return map;
}

function validateRequiredHeaders_(headerMap, requiredHeaders) {
  const missing = requiredHeaders.filter(h => !headerMap[h]);
  if (missing.length) {
    throw new Error(`Missing required headers in PAYROLL_CONTROL: ${missing.join(', ')}`);
  }
}

/**
 * Returns rows that already have PAYROLL_WORKINGS_FILE_NAME filled.
 * These are the rows to protect.
 */
function getProtectedRowsByFileName_(sheet, headerMap) {
  const col = headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_NAME];
  const lastRow = sheet.getLastRow();
  if (lastRow < PCC.INPUTS.FIRST_DATA_ROW) return [];

  const values = sheet.getRange(PCC.INPUTS.FIRST_DATA_ROW, col, lastRow - PCC.INPUTS.HEADER_ROW, 1).getDisplayValues();
  const rows = [];

  for (let i = 0; i < values.length; i++) {
    const v = String(values[i][0] || '').trim();
    if (v) rows.push(PCC.INPUTS.FIRST_DATA_ROW + i);
  }

  return rows;
}

/**
 * Finds the first row where LOCK_STATUS is not LOCKED.
 * This is the active row allowed for processing.
 */
function findFirstUnlockedRow_(sheet, headerMap) {
  const lastRow = Math.max(sheet.getLastRow(), PCC.INPUTS.FIRST_DATA_ROW);
  const numRows = Math.max(1, lastRow - PCC.INPUTS.HEADER_ROW);
  const values = sheet.getRange(PCC.INPUTS.FIRST_DATA_ROW, headerMap[PCC.HEADERS.LOCK_STATUS], numRows, 1).getDisplayValues();

  for (let i = 0; i < values.length; i++) {
    const v = String(values[i][0] || '').trim().toUpperCase();
    if (v !== PCC.VALUES.LOCK_STATUS_LOCKED) {
      return PCC.INPUTS.FIRST_DATA_ROW + i;
    }
  }

  return lastRow + 1;
}

/**
 * Stops processing if any lower row already contains data
 * before the current active row is completed and locked.
 */
function validateSequentialEntryDiscipline_(sheet, headerMap, pendingRow) {
  const lastRow = sheet.getLastRow();
  if (lastRow <= pendingRow) {
    return { block: false, message: '' };
  }

  const columnsToCheck = [
    headerMap[PCC.HEADERS.PAYROLL_MONTH_KEY],
    headerMap[PCC.HEADERS.MONTH],
    headerMap[PCC.HEADERS.YEAR],
    headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_NAME],
    headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_ID],
    headerMap[PCC.HEADERS.LOCK_STATUS],
    headerMap[PCC.HEADERS.CREATED_ON],
    headerMap[PCC.HEADERS.CREATED_BY],
  ];

  const startRow = pendingRow + 1;
  const numRows = lastRow - pendingRow;

  for (let i = 0; i < columnsToCheck.length; i++) {
    const col = columnsToCheck[i];
    const values = sheet.getRange(startRow, col, numRows, 1).getDisplayValues();

    for (let r = 0; r < values.length; r++) {
      const rowNum = startRow + r;
      const value = String(values[r][0] || '').trim();
      if (value) {
        return {
          block: true,
          message:
            `Row ${pendingRow} must be completed and LOCK_STATUS must be LOCKED before using lower rows.\n` +
            `Data is already present in row ${rowNum}.\n\n` +
            `Please clear all lower-row entries and proceed strictly in order.`,
        };
      }
    }
  }

  return { block: false, message: '' };
}

/**
 * Duplicate checks inside PAYROLL_CONTROL:
 * 1) same month key + PAYROLL_WORKINGS_FILE_NAME already filled => block
 * 2) same month key already LOCKED in another row => block
 * 3) exact file name already visible in PAYROLL_WORKINGS_FILE_NAME column => block
 *
 * Skips the current target row.
 */
function checkDuplicateInControl_(sheet, headerMap, payrollMonthKey, fileName, skipRow) {
  const lastRow = sheet.getLastRow();
  if (lastRow < PCC.INPUTS.FIRST_DATA_ROW) {
    return { block: false, message: '' };
  }

  const lastCol = sheet.getLastColumn();
  const data = sheet.getRange(PCC.INPUTS.FIRST_DATA_ROW, 1, lastRow - PCC.INPUTS.HEADER_ROW, lastCol).getDisplayValues();

  const monthKeyCol = headerMap[PCC.HEADERS.PAYROLL_MONTH_KEY] - 1;
  const fileNameCol = headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_NAME] - 1;
  const lockStatusCol = headerMap[PCC.HEADERS.LOCK_STATUS] - 1;

  for (let i = 0; i < data.length; i++) {
    const rowNum = PCC.INPUTS.FIRST_DATA_ROW + i;
    if (rowNum === skipRow) continue;

    const rowMonthKey = String(data[i][monthKeyCol] || '').trim();
    const rowFileNameDisplay = String(data[i][fileNameCol] || '').trim();
    const rowLockStatus = String(data[i][lockStatusCol] || '').trim().toUpperCase();

    if (rowFileNameDisplay === fileName) {
      return {
        block: true,
        message: `A row already exists for "${fileName}" in PAYROLL_CONTROL (row ${rowNum}). Duplicate creation is blocked.`,
      };
    }

    if (rowMonthKey === payrollMonthKey && rowFileNameDisplay) {
      return {
        block: true,
        message: `Payroll workings already exists for month "${payrollMonthKey}" in row ${rowNum}. Duplicate creation is blocked.`,
      };
    }

    if (rowMonthKey === payrollMonthKey && rowLockStatus === PCC.VALUES.LOCK_STATUS_LOCKED) {
      return {
        block: true,
        message: `This payroll month "${payrollMonthKey}" is already LOCKED in row ${rowNum}. New workings creation is blocked.`,
      };
    }
  }

  return { block: false, message: '' };
}

/**
 * Exact file name check in target folder.
 */
function folderHasExactFileName_(folderId, fileName) {
  const folder = DriveApp.getFolderById(folderId);
  const files = folder.getFilesByName(fileName);
  return files.hasNext();
}

/**
 * Updates META_DATA tab in copied file.
 * Expected structure:
 * Column A = KEY
 * Column B = VALUE
 * Only updates keys that exist. Does not clear anything else.
 */
function updateMetaDataKeys_(spreadsheet, updates) {
  const sh = spreadsheet.getSheetByName(PCC.SHEETS.META_DATA);
  if (!sh) throw new Error(`Sheet not found in copied file: ${PCC.SHEETS.META_DATA}`);

  const lastRow = sh.getLastRow();
  if (lastRow < 2) throw new Error('META_DATA does not contain enough rows.');

  const keys = sh.getRange(1, 1, lastRow, 2).getDisplayValues();
  const foundRows = {};

  for (let i = 0; i < keys.length; i++) {
    const key = String(keys[i][0] || '').trim();
    if (key) foundRows[key] = i + 1;
  }

  Object.keys(updates).forEach(key => {
    if (foundRows[key]) {
      sh.getRange(foundRows[key], 2).setValue(updates[key]);
    }
  });
}

/**
 * Removes only script-managed protections.
 */
function removeScriptManagedProtections_(sheet) {
  const protections = sheet.getProtections(SpreadsheetApp.ProtectionType.RANGE);

  protections.forEach(protection => {
    const desc = String(protection.getDescription() || '');
    if (desc.indexOf(PCC.PROTECTION.DESCRIPTION_PREFIX) === 0) {
      protection.remove();
    }
  });
}

/**
 * Recreates protections for the required cells in each protected row:
 * - PAYROLL_MONTH_KEY, MONTH, YEAR
 * - PAYROLL_WORKINGS_FILE_NAME, PAYROLL_WORKINGS_FILE_ID
 * - CREATED_ON, CREATED_BY
 */
function restoreManagedProtections_(sheet, headerMap, rowNumbers) {
  const uniqueRows = Array.from(new Set((rowNumbers || []).filter(r => Number(r) >= PCC.INPUTS.FIRST_DATA_ROW))).sort((a, b) => a - b);
  if (!uniqueRows.length) return;

  uniqueRows.forEach(rowNum => {
    protectRangeBlock_(sheet, rowNum, headerMap[PCC.HEADERS.PAYROLL_MONTH_KEY], headerMap[PCC.HEADERS.YEAR], `ROW_${rowNum}_A`);
    protectRangeBlock_(sheet, rowNum, headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_NAME], headerMap[PCC.HEADERS.PAYROLL_WORKINGS_FILE_ID], `ROW_${rowNum}_B`);
    protectRangeBlock_(sheet, rowNum, headerMap[PCC.HEADERS.CREATED_ON], headerMap[PCC.HEADERS.CREATED_BY], `ROW_${rowNum}_C`);
  });
}

function protectRangeBlock_(sheet, rowNum, startCol, endCol, suffix) {
  if (!startCol || !endCol) return;

  const range = sheet.getRange(rowNum, startCol, 1, endCol - startCol + 1);
  const protection = range.protect();
  protection.setDescription(`${PCC.PROTECTION.DESCRIPTION_PREFIX}_${suffix}`);

  const me = Session.getEffectiveUser();
  const editors = protection.getEditors();
  if (editors.length) protection.removeEditors(editors);

  protection.addEditor(me);

  if (protection.canDomainEdit()) {
    protection.setDomainEdit(false);
  }
}
